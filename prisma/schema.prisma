generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "cockroachdb"
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String 
  author    String 
  priority  Boolean  @default(false)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  pombo     String?  @unique

  accessKey String?
  expiresAt DateTime?

  // Relação de Membro (Funcionário)
  companyId String?
  company   Company? @relation("CompanyMembers", fields: [companyId], references: [id])
  
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id])

  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  // Relação de Dono (Empresas que este usuário criou)
  ownedCompanies Company[] @relation("CompanyOwner")
  paymentsReceived Payment[] @relation("UserPayments")
  paymentsMade     Payment[] @relation("PayerUser")
  requests  HireRequest[]
  logs      CompanyLog[]
}

model Company {
  id            String   @id @default(uuid())
  name          String
  
  ownerId       String   
  owner         User     @relation("CompanyOwner", fields: [ownerId], references: [id])

  webhookVendas String?
  webhookLogs   String?
  
  colorPrimary  String   @default("#8b0000")
  colorAccent   String   @default("#ff4c4c")

  enableMarket  Boolean  @default(true)
  enableHireRequest Boolean @default(true)

  users         User[]        @relation("CompanyMembers")
  roles         Role[]
  hireRequests  HireRequest[]
  crafts        Craft[]
  pedidos       Pedido[]
  logs          CompanyLog[]
  avisos        Announcement[]
  pagamentos       Payment[]
  contratos       Contract[]
}

model Contract {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  description String
  reward      Decimal  @default(0.0)
  status      String   @default("ABERTO") 
 
  completedBy String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)

  // Dono que efetuou o pagamento (opcional, pois fica nulo enquanto a ação for apenas "pendente")
  paidById    String?
  paidBy      User?    @relation("PayerUser", fields: [paidById], references: [id])

  action      String
  amount      Decimal  @default(0.0)
  status      String   @default("PENDENTE")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyLog {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  action    String   
  details   String   
  category  String   @default("GERAL") 
  
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Role {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  isOwner   Boolean @default(false)
  canVendas Boolean @default(true)
  canCraft  Boolean @default(true)
  canLogs   Boolean @default(false)
  canAdmin  Boolean @default(false)

  users     User[]
}

model HireRequest {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
}

model AccessKey {
  id        String   @id @default(uuid())
  key       String   @unique
  days      Int      @default(30)
  used      Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())
}

model Craft {
  id        String   @id @default(uuid())
  name      String
  unit      String
  price     Decimal  @default(0.0)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  insumos   String   @default("[]")
}

model Pedido {
  id        String   @id @default(uuid())
  name      String
  pombo     String   
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  produtos  String   @default("[]")
  status    String   @default("pendente")
}

model Queue {
  id        String   @id @default(uuid())
  taskName  String
  payload   String   @default("{}")
  status    String   @default("pending")
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}